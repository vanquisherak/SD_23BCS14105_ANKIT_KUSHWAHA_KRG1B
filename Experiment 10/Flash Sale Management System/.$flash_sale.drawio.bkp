<mxfile host="Electron" agent="Mozilla/5.0" version="29.5.2">
  <diagram name="Horizontal Detailed HLD" id="flash_sale_horizontal_02">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <mxCell id="title" value="&lt;b&gt;System Design:&lt;/b&gt; To design a Detailed Flash Sale Management System" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="550" height="30" as="geometry" />
        </mxCell>

        <mxCell id="fr_title" value="Functional Requirements" style="whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fr_1" value="1. Users can view active/upcoming sales." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="35" y="120" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fr_2" value="2. Users can attempt to purchase items." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="35" y="150" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fr_3" value="3. Deduct inventory without overselling." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="35" y="180" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fr_4" value="4. Users receive async order updates." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="35" y="210" width="250" height="30" as="geometry" />
        </mxCell>

        <mxCell id="nfr_title" value="Non-Functional Requirements" style="whiteSpace=wrap;html=1;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="270" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="nfr_1" value="1. Extreme High Availability &amp;amp; Throughput." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="35" y="310" width="270" height="30" as="geometry" />
        </mxCell>
        <mxCell id="nfr_2" value="2. Strict Consistency (Atomic Inventory)." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="35" y="340" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="nfr_3" value="3. Low Latency (Caching heavy)." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="35" y="370" width="210" height="30" as="geometry" />
        </mxCell>

