          <mxGeometry x="40" y="430" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="api_1" value="1. POST: /api/v1/flashsale/buy" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="35" y="470" width="190" height="30" as="geometry" />
