        <mxCell id="api_3" value="{&lt;br&gt;&amp;nbsp; &quot;userId&quot;: &quot;usr_99&quot;,&lt;br&gt;&amp;nbsp; &quot;itemId&quot;: &quot;itm_01&quot;&lt;br&gt;}" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
