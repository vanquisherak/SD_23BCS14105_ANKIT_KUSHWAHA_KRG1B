        <mxCell id="n-mgspe5zVpaZVuCbiQK-28" parent="n-mgspe5zVpaZVuCbiQK-82" style="image;sketch=0;aspect=fixed;html=1;points=[];align=center;fontSize=12;image=img/lib/mscae/Cache_Redis_Product.svg;" value="" vertex="1">
          <mxGeometry height="69.47" width="82.7" as="geometry" />
        </mxCell>
        <mxCell id="n-mgspe5zVpaZVuCbiQK-30" parent="n-mgspe5zVpaZVuCbiQK-82" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Redis" vertex="1">
          <mxGeometry height="30" width="60" x="11.350000000000023" y="62.09000000000003" as="geometry" />
        </mxCell>
        <mxCell id="fr-section" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" value="&lt;b&gt;1. FUNCTIONAL REQUIREMENTS&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;Search Functionality:&lt;/b&gt; Users can discover events using filters (Event Title, City/Location, Date)&lt;br&gt;&lt;br&gt;• &lt;b&gt;Event Information Display:&lt;/b&gt; Users can view comprehensive event details (Seats available vs. occupied, Description, Metadata - cast, duration, language, ratings)&lt;br&gt;&lt;br&gt;• &lt;b&gt;Booking Execution:&lt;/b&gt; Users can select a seat and complete a transaction to book a ticket" vertex="1">
          <mxGeometry height="200" width="500" x="50" y="1300" as="geometry" />
        </mxCell>
        <mxCell id="nfr-section" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" value="&lt;b&gt;2. NON-FUNCTIONAL REQUIREMENTS&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;Target Scale:&lt;/b&gt; Support 100 Million Daily Active Users (DAU)&lt;br&gt;&lt;br&gt;• &lt;b&gt;High Availability:&lt;/b&gt; Search/View operations prioritize being always online. Better to show slightly older data than error pages (Eventual Consistency)&lt;br&gt;&lt;br&gt;• &lt;b&gt;High Consistency:&lt;/b&gt; Booking operations must be highly consistent. No two users can book the same seat simultaneously (Strong Consistency)" vertex="1">
          <mxGeometry height="180" width="500" x="580" y="1300" as="geometry" />
        </mxCell>
        <mxCell id="api-section" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;rounded=0;fontSize=13;fontStyle=1;fontColor=#333333;" value="&lt;b&gt;3. API DESIGN&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;User Service:&lt;/b&gt;&lt;br&gt;POST /api/v1/auth/register&lt;br&gt;POST /api/v1/auth/login&lt;br&gt;GET /api/v1/users/profile&lt;br&gt;&lt;br&gt;&lt;b&gt;Search Service:&lt;/b&gt;&lt;br&gt;GET /api/v1/search?q={query}&amp;location={location}&amp;date={date}&lt;br&gt;&lt;br&gt;&lt;b&gt;Event Service:&lt;/b&gt;&lt;br&gt;GET /api/v1/events/{eventId}&lt;br&gt;GET /api/v1/events?location={location}&amp;date={date}&amp;page={page}&lt;br&gt;&lt;br&gt;&lt;b&gt;Booking Service:&lt;/b&gt;&lt;br&gt;POST /api/v1/bookings (Create booking + lock seat)&lt;br&gt;POST /api/v1/bookings/{bookingId}/confirm&lt;br&gt;GET /api/v1/bookings/my&lt;br&gt;&lt;br&gt;&lt;b&gt;Payment Service:&lt;/b&gt;&lt;br&gt;POST /api/v1/payments&lt;br&gt;POST /api/v1/payments/webhook" vertex="1">
          <mxGeometry height="380" width="520" x="50" y="1510" as="geometry" />
        </mxCell>
